        setvar(VAR_TEMP_1, ITEM_FOSSILIZED_DRAKE)
    }
    if(checkitem(ITEM_FOSSILIZED_DINO) == TRUE){
        setvar(VAR_TEMP_1, ITEM_FOSSILIZED_DINO)
    }

}


script RustboroCity_DevonCorp_2F_EventScript_FossilPokemonChoosing {
    if(var(VAR_FOSSIL_AT_SCIENTIST) == ITEM_ROOT_FOSSIL){
        setvar(VAR_TEMP_2, SPECIES_LILEEP)
    }
    if(var(VAR_FOSSIL_AT_SCIENTIST) == ITEM_CLAW_FOSSIL){
        setvar(VAR_TEMP_2, SPECIES_ANORITH)
    }
    if(var(VAR_FOSSIL_AT_SCIENTIST) == ITEM_DOME_FOSSIL){
        setvar(VAR_TEMP_2, SPECIES_KABUTO)
    }
    if(var(VAR_FOSSIL_AT_SCIENTIST) == ITEM_OLD_AMBER){
        setvar(VAR_TEMP_2, SPECIES_AERODACTYL)
    }
    if(var(VAR_FOSSIL_AT_SCIENTIST) == ITEM_HELIX_FOSSIL){
        setvar(VAR_TEMP_2, SPECIES_OMANYTE)
    }
    if(var(VAR_FOSSIL_AT_SCIENTIST) == ITEM_ARMOR_FOSSIL){
        setvar(VAR_TEMP_2, SPECIES_SHIELDON)
    }
    if(var(VAR_FOSSIL_AT_SCIENTIST) == ITEM_SKULL_FOSSIL){
        setvar(VAR_TEMP_2, SPECIES_CRANIDOS)
    }
    if(var(VAR_FOSSIL_AT_SCIENTIST) == ITEM_COVER_FOSSIL){
        setvar(VAR_TEMP_2, SPECIES_TIRTOUGA)
    }
    if(var(VAR_FOSSIL_AT_SCIENTIST) == ITEM_PLUME_FOSSIL){
        setvar(VAR_TEMP_2, SPECIES_ARCHEN)
    }
    if(var(VAR_FOSSIL_AT_SCIENTIST) == ITEM_JAW_FOSSIL){
        setvar(VAR_TEMP_2, SPECIES_TYRUNT)
    }
    if(var(VAR_FOSSIL_AT_SCIENTIST) == ITEM_SAIL_FOSSIL){
        setvar(VAR_TEMP_2, SPECIES_AMAURA)
    }
    if(var(VAR_FOSSIL_AT_SCIENTIST) == ITEM_FOSSILIZED_BIRD){
        setvar(VAR_TEMP_2, SPECIES_DRACOZOLT)
    }
    if(var(VAR_FOSSIL_AT_SCIENTIST) == ITEM_FOSSILIZED_FISH){
        setvar(VAR_TEMP_2, SPECIES_ARCTOVISH)
    }
    if(var(VAR_FOSSIL_AT_SCIENTIST) == ITEM_FOSSILIZED_DRAKE){
        setvar(VAR_TEMP_2, SPECIES_DRACOVISH)
    }
    if(var(VAR_FOSSIL_AT_SCIENTIST) == ITEM_FOSSILIZED_DINO){
        setvar(VAR_TEMP_2, SPECIES_ARCTOZOLT)
    }

}

text RustboroCity_DevonCorp_2F_Text_WantToBringFossilBackToLife_Multiple {
	format (
		"Wait! That thing you have there…\n"
		"Is that a Fossil?\p"
		"You have also multiples of them.\p"
		"Would you like to bring a POKéMON\n"
		"back to life?\p"
		"I can with my newly developed\n"
		"FOSSIL REGENERATOR."
	)
}