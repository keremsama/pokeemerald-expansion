    if(checkitem(ITEM_OLD_AMBER) == TRUE){
        setvar(VAR_TEMP_1, ITEM_OLD_AMBER)
    }
    if(checkitem(ITEM_DOME_FOSSIL) == TRUE){
        setvar(VAR_TEMP_1, ITEM_DOME_FOSSIL)
    }
