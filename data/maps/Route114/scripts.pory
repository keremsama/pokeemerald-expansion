Route114_Text_AllMyMonDoesIsRoarTakeThis:
	.string "All my POKéMON does is ROAR…\n"
	.string "No one dares to come near me…\p"
	.string "Sigh… If you would, please take\n"
	.string "this TM away…$"

Route114_Text_ExplainRoar:
	.string "TM05 contains ROAR.\n"
	.string "A ROAR sends POKéMON scurrying.$"

Route114_Text_Poochyena:
	.string "Bow! Bowwow!$"

Route114_Text_MeteorFallsSign:
	.string "METEOR FALLS\n"
	.string "RUSTBORO CITY THROUGH HERE$"

Route114_Text_FossilManiacsHouseSign:
	.string "FOSSIL MANIAC'S HOUSE\n"
	.string "“Fossils gratefully accepted!”$"

Route114_Text_LanettesHouse:
	.string "LANETTE'S HOUSE$"

`

// Poryscript

script Route114_StevenEncounter1{
    if(!flag(FLAG_MEET_STEVEN_ROUTE114)){
        lockall
        addobject (Route114_Steven)
        applymovement (Route114_Steven, Steven_Movement1_1)
        waitmovement (Route114_Steven)
		applymovement (OBJ_EVENT_ID_PLAYER, moves(face_right))
    	waitmovement (OBJ_EVENT_ID_PLAYER)
        call (Route114_StevenEncounter)
        applymovement (Route114_Steven, Steven_Movement1_2)
        waitmovement (Route114_Steven)
        removeobject (Route114_Steven)
        setflag (FLAG_MEET_STEVEN_ROUTE114)
        releaseall
        end
    }
}

script Route114_StevenEncounter2{
    if(!flag(FLAG_MEET_STEVEN_ROUTE114)){
        lockall
        addobject (Route114_Steven)
        applymovement (Route114_Steven, Steven_Movement2_1)
        waitmovement (Route114_Steven)
		applymovement (OBJ_EVENT_ID_PLAYER, moves(face_right))
    	waitmovement (OBJ_EVENT_ID_PLAYER)
        call (Route114_StevenEncounter)
        applymovement (Route114_Steven, Steven_Movement2_2)
        waitmovement (Route114_Steven)
        removeobject (Route114_Steven)
        setflag (FLAG_MEET_STEVEN_ROUTE114)
        releaseall
        end
    }
}

script Route114_StevenEncounter3{
    if(!flag(FLAG_MEET_STEVEN_ROUTE114)){
        lockall
        addobject (Route114_Steven)
        applymovement (Route114_Steven, Steven_Movement3_1)
        waitmovement (Route114_Steven)
		applymovement (OBJ_EVENT_ID_PLAYER, moves(face_up))
    	waitmovement (OBJ_EVENT_ID_PLAYER)
        call (Route114_StevenEncounter)
        applymovement (Route114_Steven, Steven_Movement3_2)
        waitmovement (Route114_Steven)
        removeobject (Route114_Steven)
        setflag (FLAG_MEET_STEVEN_ROUTE114)
        releaseall
        end
    }
}

script Route114_StevenEncounter{
    msgbox(Steven_Text1)
    waitmessage
    closemessage
    delay(30)
    msgbox(Steven_Text2)
    waitmessage
    closemessage
    delay(30)
    msgbox(Steven_Text3)
    waitmessage
    closemessage
    additem(ITEM_MEGA_RING, 1)
    playfanfare(MUS_OBTAIN_BADGE)
    msgbox("{PLAYER} obtained the MEGA RING!")
    waitfanfare
    msgbox(Steven_Text4)
    waitmessage
    multichoice(25, 3, MULTI_STARTER_MEGA_STONE, 1)
    if (var(VAR_RESULT) == 0) {
        msgbox(format("So you chose Treecko as your starter? Great choice!\pHere's something for you!"))
        waitmessage
        giveitem(ITEM_SCEPTILITE, 1)
        msgbox(format("Once your partner reaches its final stage, you'll be able to unlock its full potential!"))
    }
    elif (var(VAR_RESULT) == 1) {
        msgbox(format("So you chose Mudkip as your starter? Great choice!\pHere's something for you!"))
        waitmessage
        giveitem(ITEM_SWAMPERTITE, 1)
        msgbox(format("Once your partner reaches its final stage, you'll be able to unlock its full potential!"))
    }
    elif (var(VAR_RESULT) == 2) {
        msgbox(format("So you chose Torchic as your starter? Great choice!\pHere's something for you!"))
        waitmessage
        giveitem(ITEM_BLAZIKENITE, 1)
        msgbox(format("Once your partner reaches its final stage, you'll be able to unlock its full potential!"))
    }
    waitmessage
    delay (30)
    msgbox(format("Remember, {PLAYER}, with great power comes great responsibility.\pUse the MEGA RING wisely, and you'll be able to achieve amazing things with your Pokémon!"))
    waitmessage
    closemessage
    delay (30)
    msgbox(format("I have to go now, good luck on your journey {PLAYER}!"))
    waitmessage
    closemessage
    return
}

movement Steven_Movement1_1{
    walk_down * 6
    walk_left * 2
}

movement Steven_Movement1_2{
    walk_right * 2
    walk_up * 6
}

movement Steven_Movement2_1{
	walk_down * 7
	walk_left * 2
}

movement Steven_Movement2_2{
    walk_right * 2
    walk_up * 7
}

movement Steven_Movement3_1{
	walk_down * 7
	walk_left * 3
	face_down
}

movement Steven_Movement3_2{
    walk_right * 3
    walk_up * 7
}

text Steven_Text1{
    format(
    "Steven: Hi, {PLAYER}{KUN}!\p"
    "You remember me, right?\p"
    "It's me, Steven!\n"
    "We met in the cave near Dewford.\p"
    "Have you met many kinds of Pokémon\n"
    "since I last saw you?\p"
    "There are many rare Pokémon here in Hoenn that still need to be found!"
    )
}

text Steven_Text2{
    format(
    "I have seen you battle the trainers here in the Route before.\p"
    "You have a real talent for it!\p"
    "Your Pokémon seems to like you very much, too.\p"
    "If you keep training hard, you'll become the Champion in no time!"
    )
}

text Steven_Text3{
    format(
    "I want to tell you something about MEGA-EVOLUTIONS.\p"
    "This special kind of evolution makes certain Pokémon even stronger!\p"
    "It's a power that requires responsibility, and in the wrong hands, it can cause great harm.\p"
    "I think that you are ready to use it."
    )
}

text Steven_Text4{
    format(
    "Oh, by the way:\p"
    "Which Pokemon did you choose as your first Partner?"
    )
}