// Poryscript
mapscripts FallarborTown_MoveRelearnersHouse_MapScripts {}

script FallarborTown_MoveRelearnersHouse_EvoStoneMan{
    lock
    faceplayer
    if (!flag(FLAG_EVO_STONE_MAN_FIRST_ENCOUNTER)){
        setflag (FLAG_EVO_STONE_MAN_FIRST_ENCOUNTER)
        msgbox (Slateport_EvoStoneMan_Text_FirstEncounter)
        waitmessage
        if(flag(FLAG_BADGE05_GET)){
            pokemart (EvoStone_Man_Expanded)
        }
        else{
            pokemart (EvoStone_Man) 
        }
        msgbox(format("Take care out there, Trainer.\pAnd remember - the right stone can bring out a Pokémon's true nature!"))
        waitmessage
        release
        end
    }
    msgbox(format(
        "Ah, back again, are you?\p"
        "You've got a good eye for fine stones.\p"
        "My stock's a bit different every now and then - depends on what I find out there in the wild.\p"
        "Want to take a look?"))
    waitmessage
    if(flag(FLAG_BADGE05_GET)){
        pokemart (EvoStone_Man_Expanded)
    }
    else{
        pokemart (EvoStone_Man) 
    }
    msgbox(format("Take care out there, Trainer.\pAnd remember - the right stone can bring out a Pokémon's true nature!"))
    waitmessage
    release
    end
}


script FallarborTown_MoveRelearnersHouse_EvoItemLady{
    lock
    faceplayer
    if (!flag(FLAG_EVO_ITEM_LADY_FIRST_ENCOUNTER)){
        setflag (FLAG_EVO_ITEM_LADY_FIRST_ENCOUNTER)
        msgbox (Slateport_EvoItemLady_Text_FirstEncounter)
        waitmessage
        if(flag(FLAG_BADGE05_GET)){
            pokemart (EvoItem_Lady_Expanded)
        }
        elif(flag(FLAG_BADGE04_GET)){
            pokemart (EvoItem_Lady) 
        }
        else{
            msgbox(EvoItem_Lady_Text_ImSorryNoStock)
            waitmessage
            release
            end
        }
        msgbox(format("May your Pokémon shine ever brighter.\pEvolution is just another form of growth, after all!"))
        waitmessage
        release
        end
    }
    if(!flag(FLAG_BADGE04_GET)){
        msgbox(EvoItem_Lady_Text_ImSorryNoStock)
        waitmessage
        release
        end
    }
    msgbox(format(
        "Welcome back!\p"
        "Looking for something to help your Pokémon reach their next stage?\p"
        "I might have a few new treasures since your last visit - my stock changes whenever fortune smiles on me.\p"
        "Take a look and see what catches your eye."))
    waitmessage
    if(flag(FLAG_BADGE05_GET)){
        pokemart (EvoItem_Lady_Expanded)
    }
    else{
        pokemart (EvoItem_Lady) 
    }
    msgbox(format("Take care out there, Trainer.\pAnd remember - the right stone can bring out a Pokémon's true nature!"))
    waitmessage
    release
    end
}  

