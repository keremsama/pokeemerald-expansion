text Slateport_EvoStoneMan_Text_FirstEncounter {
	format(
        "Hello there, young traveler!\p"
        "They call me the Evo-Stone Man! For years, I've studied the mysterious power hidden inside these beautiful stones.\p"
        "Each one holds the key to a Pokémon's evolution - nature's own little miracle!\p"
        "My collection changes from time to time as I find new stones on my journeys\p"
        "Care to take a look? You might find just the stone your partner's been waiting for!"
    )
}

text Slateport_EvoItemLady_Text_FirstEncounter {
    format(
        "Hey Trainer!\p"
        "You've got the look of a Trainer who cares deeply for their Pokémon\p"
        "I deal in special Evolution Items - rare trinkets and held objects that help Pokémon evolve in unique ways\p"
        "They're not easy to come by, but I do my best to keep my shelves stocked.\p"
        "Every now and then, I manage to find new ones, so be sure to check back once in a while!\p"
        "Care to browse my collection?"
    )
}

text EvoItem_Lady_Text_ImSorryNoStock {
    format (
        "Oh, dear… I'm terribly sorry!\p"
        "It seems my entire stock has sold out.\p"
        "I've placed an order for a fresh batch of Evolution Items, but the delivery hasn't arrived yet\p"
        "The supplier always takes their sweet time…\p"
        "Do come back a bit later, alright?\p"
        "I promise I'll have something special waiting for you next time!"
    )
}