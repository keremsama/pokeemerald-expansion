    ITEM_LINKING_CORD
    ITEM_DEEP_SEA_SCALE
    ITEM_DEEP_SEA_TOOTH
    ITEM_DRAGON_SCALE
    ITEM_UPGRADE
    ITEM_DUBIOUS_DISC
