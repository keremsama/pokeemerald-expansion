script Route114_FossilManiacsTunnel_UncleDigger_FossilListedScript {
    randomelement (
        ITEM_DOME_FOSSIL
        ITEM_OLD_AMBER
        ITEM_HELIX_FOSSIL
        ITEM_ROOT_FOSSIL
        ITEM_CLAW_FOSSIL
        ITEM_ARMOR_FOSSIL
        ITEM_SKULL_FOSSIL
        ITEM_COVER_FOSSIL
        ITEM_PLUME_FOSSIL
        ITEM_JAW_FOSSIL
        ITEM_SAIL_FOSSIL
        ITEM_FOSSILIZED_BIRD
        ITEM_FOSSILIZED_FISH
        ITEM_FOSSILIZED_DRAKE
        ITEM_FOSSILIZED_DINO
    )
}


script Route114_FossilManiacsTunnel_UncleDigger_NotEnoughMoney {
    hidemoneybox
    msgbox (format("You need ¥300 for me to dig..."))
    release
    end    
}

script Route114_FossilManiacsTunnel_UncleDigger_ComeBackAgain {
    hidemoneybox
    msgbox (format("No digging? No worries, come back anytime."))
    release
    end
}

text Route114_FossilManiacsTunnel_UncleDigger_YouGotAFossil {
    format (
        "Oh ho! Would you look at that!\p"
        "A real fossil - a {STR_VAR_1}, and in remarkable condition.\p"
        "Here, it's yours! Who knows what might be revived from it someday!"
    )
}


text Route114_FossilManiacsTunnel_UncleDigger_Text_FirstEncounter {
    format (
        "Hey there, traveler!\p"
        "My nephew is absolutely obsessed with his fossils, "
        "and he claims everything he finds here for himself.\p"
        "But for ¥300, I can do some digging for you.\p"
        "Who knows what you might uncover here in this tunnel."      
    )
}

