        ITEM_HYPER_POTION
        ITEM_MAX_POTION
        ITEM_FULL_RESTORE
        ITEM_REVIVE
        ITEM_MAX_REVIVE
        ITEM_ENERGY_ROOT
        ITEM_ANTIDOTE
        ITEM_PARALYZE_HEAL
        ITEM_PARALYZE_HEAL
        ITEM_BURN_HEAL
        ITEM_ICE_HEAL
        ITEM_AWAKENING
        ITEM_FULL_HEAL
        ITEM_ETHER
